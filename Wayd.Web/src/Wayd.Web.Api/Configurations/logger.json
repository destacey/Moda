{
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console"
        ],
        "Enrich": [
            "FromLogContext",
            "WithAssemblyName",
            "WithAssemblyVersion",
            "WithMachineName",
            "WithProcessId",
            "WithThreadId",
            "WithHangfireContext",
            "WithExceptionDetails",
            {
                "Name": "WithSpan",
                "Args": {
                    "spanOptions": {
                        "IncludeTags": "true",
                        "IncludeBaggage": "true",
                        "IncludeOperationName": "true",
                        "IncludeTraceFlags": "true"
                    }
                }
            }
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Hangfire": "Warning",
                "Microsoft": "Error",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.IdentityModel": "Fatal",
                "System": "Information",
                "ZymLabs.NSwag.FluentValidation": "Warning"
            }
        },
        "Properties": {
            "Application": "Wayd"
        },
        "WriteTo": [
            { "Name": "Console" }
        ]
    }
}