{
  "name": "@modanpm/moda-mcp",
  "version": "0.0.1",
  "description": "MCP server for the Moda work management API",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "moda-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node build/index.js",
    "build": "tsc && shx chmod 755 build/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "moda",
    "model-context-protocol",
    "work-management",
    "project-management"
  ],
  "license": "MIT",
  "homepage": "https://destacey.github.io/Moda",
  "bugs": {
    "url": "https://github.com/destacey/Moda/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/destacey/Moda.git",
    "directory": "Moda.Web/src/Moda.Mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "json-schema-to-zod": "^2.6.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.15.2",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "shx": "^0.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0"
  }
}
